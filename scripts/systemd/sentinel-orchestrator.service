[Unit]
Description=Sentinel Portfolio Orchestrator Daemon
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/sentinel/sentiment
ExecStart=/home/ubuntu/sentinel/sentiment/venv/bin/python scripts/sentinel_orchestrator.py --background
Restart=always
RestartSec=10
StandardOutput=append:/home/ubuntu/sentinel/sentiment/logs/sentinel_orchestrator.log
StandardError=append:/home/ubuntu/sentinel/sentiment/logs/sentinel_orchestrator.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target

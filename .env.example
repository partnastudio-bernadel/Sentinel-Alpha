# ====================================================================
# OpenBB Platform News Provider API Keys
# ====================================================================

# 1. Benzinga API Key (openbb-benzinga)
BENZINGA_API_KEY=

# 2. Biztoc API Key (openbb-biztoc)
BIZTOC_API_KEY=

# 3. Financial Modeling Prep (FMP) API Key (openbb-fmp)
FMP_API_KEY=

# 4. Tiingo API Token (openbb-tiingo)
TIINGO_TOKEN=

# Note: openbb-tmx does not require any credentials.

# ====================================================================
# Non-OpenBB Provider API Keys (Official APIs)
# ====================================================================

# 5. Alpha Vantage API Key (alpha-vantage)
# Register at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# 6. NewsAPI.org API Key (news_api)
# Register at: https://newsapi.org/register
NEWS_API_KEY=

# 7. RapidAPI Key (For Seeking Alpha third-party API wrappers)
# Register at: https://rapidapi.com/apidojo/api/seeking-alpha
RAPIDAPI_KEY=

# ====================================================================
# Hugging Face and NVIDIA Model API Keys & Configuration
# ====================================================================

HUGGINGFACE_API_KEY=
HUGGINGFACE_BASE_URL = "https://router.huggingface.co/v1"
HUGGINGFACE_MODEL_NAME = "curiousily/Llama-3-8B-Instruct-Finance-RAG"
HUGGINGFACE_MODEL_NAME_FEATHERLESS = "curiousily/Llama-3-8B-Instruct-Finance-RAG:featherless-ai"
HUGGINGFACE_MODEL_NAME_OPTION_TWO = "FinGPT/fingpt-fx_llama2-7b_lora"
HUGGINGFACE_BASE_MODEL_NAME = "meta-llama/Meta-Llama-3-8B-Instruct"

NVIDIA_BASE_MODEL = "meta/llama-3.1-8b-instruct"
NVIDIA_TOOLING_MODEL = "mistralai/mistral-nemotron"
NVIDIA_EMBEDDING_MODEL = "nvidia/nv-embed-v1"
NVIDIA_API_ENDPOINT = https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=
NVIDIA_API_KEY_ALT=
# ====================================================================
# MCP Configuration Paths
# ====================================================================
# Relative or absolute path to the local forexfactory-mcp package folder
FOREXFACTORY_MCP_PATH=forexfactory-mcp
SCRAPER_TIMEOUT_MS=45000
SEC_EDGAR_USER_AGENT= # SEC Edgar compliance User-Agent header (Format: 'Company ContactEmail')


# ====================================================================
# MongoDB Atlas Connection string
# ====================================================================
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=sentinel_db
MONGODB_VECTOR_INDEX="vector_index"OPENAI_API_KEY="test"
